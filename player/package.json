{
  "name": "all-in-one-iptv-player",
  "version": "1.0.0",
  "description": "ALL-IN-One IPTV Desktop Player — Electron + React",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dev": "concurrently \"vite\" \"electron .\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": ["iptv", "m3u", "streaming", "live-tv"],
  "author": "ShoumikBalaSomu",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "concurrently": "^9.0.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "hls.js": "^1.5.0",
    "dashjs": "^4.7.0",
    "axios": "^1.7.0",
    "react-icons": "^5.4.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "dev.allinone.iptv",
    "productName": "ALL-IN-One IPTV Player",
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "AudioVideo"
    }
  }
}